# Anthropic API key - get one at https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxx

# Email address to notify on new leads and escalations
NOTIFICATION_EMAIL=jobsdoneteam@gmail.com

# Webhook URL to POST lead data to (optional - e.g. Make.com, Zapier, n8n)
WEBHOOK_URL=https://your-webhook-url.com/lead

# Allowed CORS origin (set to your domain in production)
ALLOWED_ORIGIN=https://jobsdone.team

# Port (default: 3001)
PORT=3001
